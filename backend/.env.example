# ================================================================
# AFRICAN CHILDREN INITIATIVE — ENVIRONMENT VARIABLES
# ================================================================
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in ALL values marked with ✅ FILL IN
#   3. NEVER commit your .env file to GitHub
#   4. Add .env to your .gitignore file
# ================================================================

# ----------------------------------------------------------------
# SERVER CONFIGURATION
# ----------------------------------------------------------------

# Port the backend server will run on
# Local: 5000 | Render/Railway will set this automatically
PORT=5000

# Environment: 'development' or 'production'
NODE_ENV=development

# ----------------------------------------------------------------
# PAYSTACK CREDENTIALS
# ✅ FILL IN: Get these from https://dashboard.paystack.com/#/settings/developer
# ----------------------------------------------------------------

# Your Paystack SECRET key (NEVER expose on frontend)
# Test secret key starts with: sk_test_xxxxxxxxxxxxxxxxx
# Live secret key starts with: sk_live_xxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Paystack PUBLIC key (safe for frontend)
# Test public key starts with: pk_test_xxxxxxxxxxxxxxxxx
# Live public key starts with: pk_live_xxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Paystack Webhook Secret (same as your secret key for HMAC verification)
# This is used to verify that webhook events truly come from Paystack
PAYSTACK_WEBHOOK_SECRET=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Paystack API Base URL (do not change)
PAYSTACK_BASE_URL=https://api.paystack.co

# ----------------------------------------------------------------
# DATABASE CONFIGURATION
# ✅ FILL IN: Your MongoDB connection string
# ----------------------------------------------------------------

# MongoDB Atlas (Recommended for production):
# Format: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority
# Sign up free at: https://www.mongodb.com/atlas
MONGODB_URI=mongodb+srv://youruser:yourpassword@cluster0.xxxxx.mongodb.net/aci_fundraiser?retryWrites=true&w=majority

# Local MongoDB (for development):
# MONGODB_URI=mongodb://localhost:27017/aci_fundraiser

# ----------------------------------------------------------------
# CORS & SECURITY
# ✅ FILL IN: Your frontend URL(s)
# ----------------------------------------------------------------

# Allowed origins for CORS (comma-separated if multiple)
# Local: http://localhost:3000 or file:// for plain HTML
# Production: https://your-github-username.github.io or your custom domain
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500

# Secret for any internal signing (generate a random 64-char string)
# Generate one at: https://randomkeygen.com/ or run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=your_random_64_character_secret_string_here

# ----------------------------------------------------------------
# RATE LIMITING
# ----------------------------------------------------------------

# Max requests per window per IP (for payment endpoints)
RATE_LIMIT_MAX=20

# Rate limit window in minutes
RATE_LIMIT_WINDOW_MINUTES=15

# ----------------------------------------------------------------
# LOGGING
# ----------------------------------------------------------------

# Log level: 'error' | 'warn' | 'info' | 'debug'
LOG_LEVEL=info

# Log to file? true | false
LOG_TO_FILE=false

# ----------------------------------------------------------------
# EMAIL NOTIFICATIONS (Optional — for admin alerts)
# ✅ FILL IN: Only if you want admin email alerts on donations
# ----------------------------------------------------------------

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# ADMIN_EMAIL=admin@africanchildreninitiative.org

# ----------------------------------------------------------------
# FRONTEND URL (for webhook redirect references)
# ✅ FILL IN: Your deployed frontend URL
# ----------------------------------------------------------------
FRONTEND_URL=https://your-github-username.github.io/african-children-initiative

# ----------------------------------------------------------------
# ORGANIZATION INFO
# ----------------------------------------------------------------
ORG_NAME=African Children Initiative
ORG_EMAIL=info@africanchildreninitiative.org
ORG_CURRENCY=NGN
