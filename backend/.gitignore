# ================================================================
# .gitignore — African Children Initiative
# Place this file in your project ROOT directory
# ================================================================

# Environment variables — NEVER commit these
.env
.env.local
.env.production
.env.staging
backend/.env

# Node modules
node_modules/
backend/node_modules/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*

# OS files
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Build outputs
dist/
build/
.cache/

# Coverage
coverage/

# Temporary files
tmp/
temp/
